      "questions": [
        { "id": "Q1", "text": "What is the powerhouse of the cell?", "options": ["Nucleus","Mitochondria","Ribosome","Golgi Apparatus"], "correct": 1, "solution": "The mitochondria produces ATP through cellular respiration, supplying energy to the cell." },
        { "id": "Q2", "text": "Which organelle contains the genetic information of a cell?", "options": ["Mitochondria","Lysosome","Nucleus","Vacuole"], "correct": 2, "solution": "The nucleus houses the cell's DNA and directs all cellular activities via the nuclear envelope." },
        { "id": "Q3", "text": "What structure controls what enters and exits the cell?", "options": ["Cell wall","Cell membrane","Cytoplasm","Endoplasmic reticulum"], "correct": 1, "solution": "The cell membrane is selectively permeable, regulating movement of substances in and out of the cell." },
        { "id": "Q4", "text": "Which organelle is responsible for protein synthesis?", "options": ["Golgi body","Ribosome","Lysosome","Vacuole"], "correct": 1, "solution": "Ribosomes translate mRNA into proteins and can be free in the cytoplasm or on the rough ER." },
        { "id": "Q5", "text": "What do plant cells have that animal cells do not?", "options": ["Mitochondria","Nucleus","Cell wall and chloroplasts","Ribosomes"], "correct": 2, "solution": "Plant cells uniquely have a rigid cell wall (cellulose) and chloroplasts for photosynthesis." }
      ]
